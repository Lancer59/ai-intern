# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1

# Ollama (Local)
# No API key needed, just ensure Ollama is running.
# OLLAMA_BASE_URL=http://localhost:11434

TAVILY_API_KEY=""

# Chainlit Auth (required for login + history sidebar)
CHAINLIT_AUTH_SECRET="change-this-to-a-random-secret"
CHAINLIT_USER="admin"
CHAINLIT_PASSWORD="admin"

# Debug: print the full prompt to stdout before every LLM call.
# Shows each message role, char count, and a total token estimate.
# Set to true to enable, leave blank or false for production.
DEBUG_PRINT_PROMPT=false

# Summarization middleware — triggers when conversation exceeds this many tokens.
# Set to ~75% of your model's context window.
# gpt-4o / gpt-4.1 (128k):        100000
# gpt-4-turbo (128k):              100000
# gpt-3.5-turbo (16k):             12000
# gpt-5 / gpt-5.3-instant (128k): 100000
# gpt-5.3-codex / gpt-5-codex (200k+): 150000
# gpt-5.4 / gpt-5.4-pro (1M):     750000
# claude-3-5-sonnet (200k):        150000
SUMMARIZATION_TOKEN_TRIGGER=100000
# Number of recent messages to keep after summarization
SUMMARIZATION_KEEP_MESSAGES=30